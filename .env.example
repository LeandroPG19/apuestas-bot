# ─── Entorno ─────────────────────────────────────────────────────────────────
APUESTAS_ENV=local
APUESTAS_LOG_LEVEL=INFO
APUESTAS_TZ=America/Mexico_City

# Python 3.14.4 free-threading (PEP 703).
# 0 = activar free-threaded (sin GIL); 1 = forzar GIL (fallback si alguna
# C-extension regresionara). Pineado a 0 por default tras validación.
PYTHON_GIL=0

# ─── Regional preference (MX | US | BOTH) — §22 ──────────────────────────────
REGION_PREFERENCE=BOTH

# ─── Base de datos ───────────────────────────────────────────────────────────
# Puerto externo 5433 porque PG host corre en 5432. Dentro de Docker es 5432.
POSTGRES_USER=apuestas
POSTGRES_PASSWORD=change-me-to-long-random-string
POSTGRES_DB=apuestas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql+asyncpg://apuestas:change-me-to-long-random-string@postgres:5432/apuestas

# ─── Valkey (Redis-compatible) ───────────────────────────────────────────────
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=change-me-valkey-password
VALKEY_URL=redis://:change-me-valkey-password@valkey:6379/0
TASKIQ_BROKER_URL=redis://:change-me-valkey-password@valkey:6379/1

# ─── MinIO (S3-compatible) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_ARTIFACTS=mlflow-artifacts
MINIO_BUCKET_PARQUET=parquet-cold
MINIO_BUCKET_SCRAPES=scrapes-raw

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio-admin
AWS_SECRET_ACCESS_KEY=change-me-minio-password

# ─── Prefect ─────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://prefect:4200/api

# ─── FastAPI ─────────────────────────────────────────────────────────────────
# Puerto externo 8001 porque 8000 está tomado en host
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8001
API_WORKERS=2

# ─── LLM backend selector ────────────────────────────────────────────────────
# "llama_local" = Qwen 2.5 7B Q4 local vía llama.cpp (requiere GPU + 4.7GB VRAM)
# "deepseek"    = DeepSeek API remota (OpenAI-compatible, $0.27/M tokens input)
LLM_BACKEND=deepseek

# LLM local (si LLM_BACKEND=llama_local)
LLAMA_SERVER_URL=http://llm:8080
LLAMA_MODEL=qwen2.5-7b-instruct-q4_k_m
LLAMA_CTX_SIZE=8192

# DeepSeek API (si LLM_BACKEND=deepseek) — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# "deepseek-chat"=V3.2 general | "deepseek-reasoner"=R1 razonamiento (+ caro)
DEEPSEEK_MODEL=deepseek-chat

# Embeddings (TEI local)
TEI_URL=http://embed:80
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# ─── APIs externas GRATIS (recomendadas para MVP) ────────────────────────────
# football-data.org — 10 req/min, Big-5 + Champions + Libertadores
# https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=your-football-data-org-key-here

# TheSportsDB — gratis sin key (val=3), Liga MX + MLS + muchas ligas
# https://www.thesportsdb.com/free_sports_api
THESPORTSDB_KEY=3

# OpenWeatherMap — 1000 req/día gratis
OPENWEATHERMAP_KEY=your-openweathermap-key-here

# ─── APIs externas DE PAGO (opcionales) ──────────────────────────────────────
# API-Football $19/mes — SOLO si quieres Liga MX odds+lineups realtime.
# Sin esta, el bot usa football-data.org + TheSportsDB + ESPN hidden API.
API_FOOTBALL_KEY=

# The Odds API — 500 créditos/mes GRATIS sin tarjeta. $30/mes para más.
# https://the-odds-api.com/#get-access
THE_ODDS_API_KEY=your-the-odds-api-key-here

# Sprint B abr-2026: stack odds gratuito (recorta dependencia de the-odds-api)
# Tras cablear Polymarket games + Kambi multi-operador + Pinnacle guest, the-odds-api
# queda como SAFETY NET para books US (BetMGM/Caesars/BetRivers) — bajar a free 500/mes:
THE_ODDS_API_BUDGET_MONTHLY=500
APUESTAS_ODDS_API_MIN_INTERVAL_MIN=30
ENABLE_KALSHI=true
ENABLE_ODDSJAM=true
ENABLE_POLYMARKET_GAMES=true
ENABLE_KAMBI_MULTI=true
# APUESTAS_KAMBI_OPERATORS=ub,comeon,betsson  # opcional para activar más operadores
# APUESTAS_ODDSJAM_RESET=1  # poner a 1 + reiniciar para reactivar OddsJam tras auto-disable

# Sprint C abr-2026: filtro consensus_sharp (mejora ROI de -20% → +12% según backtest 7d)
# OFF por default — activar cuando lleves 1 semana validando otros fixes.
APUESTAS_FILTER_LOW_SHARP=false
APUESTAS_MIN_P_CONSENSUS_SHARP=0.40
# Filtro selectivo por sport (vacío = todos). Empezar con soccer+nba para validar:
# APUESTAS_FILTER_LOW_SHARP_SPORTS=soccer,nba

# Sprint D abr-2026: hardening matemático F2-F8 (todos default ON salvo F1)
# F3 — rechazar picks donde el book TARGET tiene hold (overround del libro) >7%
APUESTAS_MAX_HOLD_TARGET_BOOK=0.07
# F7 — sample size guard: rechazar si modelo entrenó con <50 matches
APUESTAS_MIN_TRAIN_SAMPLES=50
# F2 — adaptive blend (modelo Brier 0.20 → peso 1.5×, 0.25 → 0.5×)
APUESTAS_ADAPTIVE_BLEND=true
# F4 — slippage guard: cancelar pick si la cuota actual <95% de la emitida
APUESTAS_SLIPPAGE_GUARD=true
APUESTAS_SLIPPAGE_TOLERANCE=0.05
# F5 — CLV anti-stale: cancelar si Pinnacle se mueve >2% en contra en 30min
APUESTAS_CLV_ANTISTALE=true
APUESTAS_CLV_DRIFT_TOLERANCE=0.02
# F6 — drift auto-degradate ya activo en drift_monitor_flow; sin env vars

# Visual Crossing — $0.0001/record opcional para backfill weather 5y
VISUAL_CROSSING_KEY=

# ─── Reddit (asyncpraw) ──────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=apuestas-bot/0.1 by u/yourusername

# ─── Telegram (long-polling mode) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-numeric-chat-id
# Canal de difusión (opcional). Si lo configuras, cada pick se publica
# también al canal (solo lectura, suscriptores ilimitados).
#   Formato público:  @nombre_canal      (ej. @ApuestasCuPicks)
#   Formato privado:  -1001234567890     (el ID numérico del canal)
# El bot debe ser admin del canal con permiso "Post messages".
TELEGRAM_CHANNEL_ID=

# ─── MCP (local stdio) ───────────────────────────────────────────────────────
# cuba-memorys: memoria persistente del bot (19 tools Oja/Elo/conformal/faro...)
# cuba-search: research multi-fuente para brief deep de picks top-EV
#
# Opciones de CMD según cómo los tengas instalados:
#   Binario custom (compilado):   /usr/local/bin/cuba-memorys-server
#   Via npm global:               npx -y @cuba/memorys-server
#   Via pipx:                     pipx run cuba-memorys
#
# Si el comando no existe o falla → MCP degrada grácilmente (sin alarma,
# solo log info "mcp_disabled_no_binary"); el bot sigue corriendo sin
# contexto histórico (análisis LLM será menos preciso pero funcional).
APUESTAS_USE_MCP=true
CUBA_MEMORYS_STDIO_CMD=/usr/local/bin/cuba-memorys-server
CUBA_SEARCH_STDIO_CMD=/usr/local/bin/cuba-search-server

# ─── Detector (modo alertas de valor, sin bankroll) ─────────────────────────
# Post-pivote 2026-04-23: el bot no maneja stake ni banca. Sólo emite
# alertas cuando detecta edge +EV sobre odds fair Pinnacle de-vigged.
EV_THRESHOLD=0.03
MIN_ODDS=1.50
MAX_ODDS=4.00

# ─── Observabilidad ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel:4317
OTEL_SERVICE_NAME=apuestas
SENTRY_DSN=

# ─── Flags ──────────────────────────────────────────────────────────────────
APUESTAS_PAPER_TRADING=true
APUESTAS_AUTO_POSTMORTEM=true
APUESTAS_ENABLE_LLM_ENRICHMENT=true
APUESTAS_ENABLE_RAG=true
APUESTAS_ENABLE_MCP=true

# ─── Fuentes de odds gratis (§15.4 del plan) ─────────────────────────────────
# Pinnacle guest API: funciona sin config, siempre activo como benchmark sharp.
#
# Betfair Exchange (opcional). Requiere cuenta Betfair + App Key delayed gratis:
#   https://apps.betfair.com/visualisers/api-ng-account-operations/
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_CERT_PATH=  # opcional — path a .pem para login non-interactive

# US books scraping (DraftKings/FanDuel/BetMGM via camoufox).
# State válido: nj, pa, co, in, mi, ny, va, nh, oh, il, ks, md, tn, ia, wv
APUESTAS_US_BOOKS_STATE=nj
# DraftKings: menos agresivo contra scraping → activado por default.
APUESTAS_ENABLE_DK=true
# FanDuel / BetMGM: TOS más estricto, off por default.
APUESTAS_ENABLE_FANDUEL=false
APUESTAS_ENABLE_BETMGM=false
# Gap #13: Guard obligatorio de VPN US. Si false, se salta el scraping completo
# sin gastar camoufox. Cuando actives la VPN, ponlo en true.
# El bot verifica ipinfo.io (país = US) con cache 5 min.
APUESTAS_US_VPN_ACTIVE=false

# Gap #5: player props MVP (NBA points + MLB HR). Off por default hasta tener
# histórico de samples >= 10 games para entrenar distribución Poisson/NegBin.
APUESTAS_ENABLE_PROPS=false

# Fase 5.10 — Offshore sportsbooks soft-book (accesibles MX+US sin VPN).
# Activar individualmente según preferencia del usuario. TOS grey area —
# uso personal únicamente.
APUESTAS_ENABLE_BETUS=false
APUESTAS_ENABLE_BETWHALE=false
APUESTAS_ENABLE_EVERYGAME=false
APUESTAS_ENABLE_SPORTSBETTING_AG=false
# BC.GAME = crypto-only (BTC/ETH/USDT). Activar solo si wallet configurado.
APUESTAS_ENABLE_BC_GAME=false

# Fase 5.11 — MX regulados SEGOB adicionales.
# Complementan Caliente + Codere (ya existentes). Total 5 books MX regulados.
APUESTAS_ENABLE_WINPOT=false
APUESTAS_ENABLE_CAMPOBET=false
APUESTAS_ENABLE_JUGABET=false

# Fase 5 — Sofascore stats scraping (player ratings, xG, H2H, form).
# TOS grey area para comercial, uso personal ok. Habilita +2-4% precisión.
APUESTAS_ENABLE_SOFASCORE=false

# ─── Deep analysis tuning ───────────────────────────────────────────────────
# Threshold mínimo de completitud (§16.6). Default 0.70 (producción).
# Bajar a 0.20 para modo degradado cuando APIs externas están limitadas.
APUESTAS_MIRROR_MIN_COMPLETENESS=0.70

# ─── API hardening (opcional; defaults permisivos en dev) ───────────────────
# APUESTAS_ALLOWED_HOSTS=apuestas.local,192.168.1.100
# APUESTAS_CORS_ORIGINS=http://localhost:3000
# APUESTAS_METRICS_TOKEN=
