# ─── Entorno ─────────────────────────────────────────────────────────────────
APUESTAS_ENV=local
APUESTAS_LOG_LEVEL=INFO
APUESTAS_TZ=America/Mexico_City

# Python 3.14.4 free-threading (PEP 703).
# 0 = activar free-threaded (sin GIL); 1 = forzar GIL (fallback si alguna
# C-extension regresionara). Pineado a 0 por default tras validación.
PYTHON_GIL=0

# ─── Regional preference (MX | US | BOTH) — §22 ──────────────────────────────
REGION_PREFERENCE=BOTH

# ─── Base de datos ───────────────────────────────────────────────────────────
# Puerto externo 5433 porque PG host corre en 5432. Dentro de Docker es 5432.
POSTGRES_USER=apuestas
POSTGRES_PASSWORD=change-me-to-long-random-string
POSTGRES_DB=apuestas
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql+asyncpg://apuestas:change-me-to-long-random-string@postgres:5432/apuestas

# ─── Valkey (Redis-compatible) ───────────────────────────────────────────────
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=change-me-valkey-password
VALKEY_URL=redis://:change-me-valkey-password@valkey:6379/0
TASKIQ_BROKER_URL=redis://:change-me-valkey-password@valkey:6379/1

# ─── MinIO (S3-compatible) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minio-admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_ARTIFACTS=mlflow-artifacts
MINIO_BUCKET_PARQUET=parquet-cold
MINIO_BUCKET_SCRAPES=scrapes-raw

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minio-admin
AWS_SECRET_ACCESS_KEY=change-me-minio-password

# ─── Prefect ─────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://prefect:4200/api

# ─── FastAPI ─────────────────────────────────────────────────────────────────
# Puerto externo 8001 porque 8000 está tomado en host
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8001
API_WORKERS=2

# ─── LLM backend selector ────────────────────────────────────────────────────
# "llama_local" = Qwen 2.5 7B Q4 local vía llama.cpp (requiere GPU + 4.7GB VRAM)
# "deepseek"    = DeepSeek API remota (OpenAI-compatible, $0.27/M tokens input)
LLM_BACKEND=deepseek

# LLM local (si LLM_BACKEND=llama_local)
LLAMA_SERVER_URL=http://llm:8080
LLAMA_MODEL=qwen2.5-7b-instruct-q4_k_m
LLAMA_CTX_SIZE=8192

# DeepSeek API (si LLM_BACKEND=deepseek) — https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# "deepseek-chat"=V3.2 general | "deepseek-reasoner"=R1 razonamiento (+ caro)
DEEPSEEK_MODEL=deepseek-chat

# Embeddings (TEI local)
TEI_URL=http://embed:80
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024

# ─── APIs externas GRATIS (recomendadas para MVP) ────────────────────────────
# football-data.org — 10 req/min, Big-5 + Champions + Libertadores
# https://www.football-data.org/client/register
FOOTBALL_DATA_ORG_KEY=your-football-data-org-key-here

# TheSportsDB — gratis sin key (val=3), Liga MX + MLS + muchas ligas
# https://www.thesportsdb.com/free_sports_api
THESPORTSDB_KEY=3

# OpenWeatherMap — 1000 req/día gratis
OPENWEATHERMAP_KEY=your-openweathermap-key-here

# ─── APIs externas DE PAGO (opcionales) ──────────────────────────────────────
# API-Football $19/mes — SOLO si quieres Liga MX odds+lineups realtime.
# Sin esta, el bot usa football-data.org + TheSportsDB + ESPN hidden API.
API_FOOTBALL_KEY=

# The Odds API — 500 créditos/mes GRATIS sin tarjeta. $30/mes para más.
# https://the-odds-api.com/#get-access
THE_ODDS_API_KEY=your-the-odds-api-key-here

# Visual Crossing — $0.0001/record opcional para backfill weather 5y
VISUAL_CROSSING_KEY=

# ─── Reddit (asyncpraw) ──────────────────────────────────────────────────────
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=apuestas-bot/0.1 by u/yourusername

# ─── Telegram (long-polling mode) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-numeric-chat-id

# ─── MCP (local stdio) ───────────────────────────────────────────────────────
APUESTAS_USE_MCP=true
CUBA_MEMORYS_STDIO_CMD=/usr/local/bin/cuba-memorys-server
CUBA_SEARCH_STDIO_CMD=/usr/local/bin/cuba-search-server

# ─── Betting defaults ────────────────────────────────────────────────────────
DEFAULT_BANKROLL_UNITS=200
KELLY_FRACTION=0.25
KELLY_MAX_STAKE_PCT=0.05
EV_THRESHOLD=0.03
MIN_ODDS=1.50
MAX_ODDS=4.00

# ─── Observabilidad ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel:4317
OTEL_SERVICE_NAME=apuestas
SENTRY_DSN=

# ─── Flags ──────────────────────────────────────────────────────────────────
APUESTAS_PAPER_TRADING=true
APUESTAS_AUTO_POSTMORTEM=true
APUESTAS_ENABLE_LLM_ENRICHMENT=true
APUESTAS_ENABLE_RAG=true
APUESTAS_ENABLE_MCP=true
